---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/layout/Header.svelte";
import AppShell from "../components/layout/AppShell.svelte";
import "../styles/global.css";
---

<BaseLayout
  title="ゲロルトの工匠記録 | FF14"
  description="FF14 レリック武器の作成進捗を管理するツール。武器・ジョブごとに達成済みの実績を確認できます。"
>
  <div class="flex flex-col min-h-screen">
    <Header client:load />
    <main class="flex-1">
      <AppShell client:load />
    </main>
    <footer class="border-t border-gs-border bg-gs-panel px-4 py-3 flex flex-wrap items-center justify-between gap-2 text-xs text-gs-muted">
      <span>Illust: <a href="https://twitter.com/toto_lucas_ff14" target="_blank" rel="noopener" class="text-gs-gold hover:underline">ろにゃ</a></span>
      <span>© SQUARE ENIX</span>
    </footer>
  </div>

  <!-- ストア初期化 + URL sync -->
  <script>
    import { WEAPONS, selectedWeapon, selectedJob } from "../stores/selection.js";
    import { initCharacterStore } from "../stores/character.js";

    initCharacterStore();

    let _syncing = true;
    let _curWeapon = WEAPONS[0];
    let _curJob    = "";

    selectedWeapon.subscribe(w => { _curWeapon = w; syncUrl(); });
    selectedJob.subscribe(j    => { _curJob    = j; syncUrl(); });

    function syncUrl() {
      if (_syncing) return;
      const p = new URLSearchParams(location.search);
      p.set("weapon", _curWeapon.key);
      if (_curJob) p.set("job", _curJob); else p.delete("job");
      const qs = "?" + p.toString();
      if (location.search !== qs)
        history.replaceState(null, "", location.pathname + qs);
    }

    function readFromUrl() {
      const p      = new URLSearchParams(location.search);
      const wKey   = p.get("weapon");
      const jKey   = p.get("job");
      const weapon = wKey ? WEAPONS.find(w => w.key === wKey) : null;
      if (weapon) {
        selectedWeapon.set(weapon);
        if (jKey && weapon.jobs.includes(jKey)) selectedJob.set(jKey);
      }
      _syncing = false;
      syncUrl();
    }

    readFromUrl();
  </script>

</BaseLayout>
