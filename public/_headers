# 静的アイコン・画像（変更なし → 1年キャッシュ）
/icon/*
  Cache-Control: public, max-age=31536000, immutable

/logo/*
  Cache-Control: public, max-age=31536000, immutable

# Astro がハッシュ付きで出力するビルド成果物
/_assets/*
  Cache-Control: public, max-age=31536000, immutable

# データファイル（更新の可能性あり → 1時間）
/data/*
  Cache-Control: public, max-age=3600
